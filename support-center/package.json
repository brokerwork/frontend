{
  "name": "support-center",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "dependencies": {
    "babel-polyfill": "6.23.0",
    "bluebird": "3.5.0",
    "bowser": "1.7.0",
    "decorate-component-with-props": "^1.1.0",
    "draft-convert": "^2.0.1",
    "draft-js": "^0.10.5",
    "draft-js-color-picker": "^1.0.2",
    "draft-js-export-html": "^0.5.4",
    "draft-js-plugins-editor": "^2.0.0-beta1",
    "draft-js-table-plugin": "^1.0.4",
    "html-to-draftjs": "0.1.0-beta11",
    "intl": "1.2.5",
    "isomorphic-fetch": "2.2.1",
    "js-cookie": "2.1.4",
    "moment": "2.20.1",
    "rc-datetime-picker": "^1.6.1",
    "react": "15.5.4",
    "react-ckeditor-wrapper": "1.1.2",
    "react-code-splitting": "^1.1.1",
    "react-copy-to-clipboard": "^5.0.1",
    "react-dom": "15.5.4",
    "react-intl": "2.3.0",
    "react-redux": "5.0.5",
    "react-router": "4.1.1",
    "react-router-dom": "4.1.1",
    "react-router-redux": "next",
    "react-transition-group": "1.1.3",
    "redux": "3.6.0",
    "redux-actions": "2.0.3",
    "redux-form": "6.7.0",
    "redux-logger": "3.0.6",
    "redux-promise": "0.5.3",
    "sortablejs": "^1.6.0",
    "thread-loader": "^2.1.2"
  },
  "devDependencies": {
    "add-asset-html-webpack-plugin": "^3.1.3",
    "babel-core": "^6.24.1",
    "babel-eslint": "^8.0.0",
    "babel-jest": "20.0.3",
    "babel-loader": "7",
    "babel-preset-es2015": "6.24.1",
    "babel-preset-react": "6.24.1",
    "babel-preset-stage-0": "6.24.1",
    "copy-webpack-plugin": "^5.0.3",
    "css-loader": "^2.1.1",
    "cssnano": "^3.10.0",
    "cz-conventional-changelog": "2.0.0",
    "enzyme": "2.9.1",
    "eslint": "^4.7.0",
    "prettier": "^1.7.0",
    "eslint-config-prettier": "^2.5.0",
    "eslint-plugin-prettier": "^2.3.0",
    "extract-text-webpack-plugin": "^4.0.0-beta.0",
    "file-loader": "^3.0.1",
    "friendly-errors-webpack-plugin": "^1.7.0",
    "happypack": "^5.0.1",
    "html-webpack-plugin": "^3.2.0",
    "husky": "0.13.3",
    "ip": "1.1.5",
    "jest": "20.0.4",
    "jest-enzyme": "3.8.0",
    "less": "2.7.2",
    "less-loader": "^4.0.3",
    "mini-css-extract-plugin": "^0.6.0",
    "node-notifier": "^5.1.2",
    "os": "^0.1.1",
    "oss-easy": "0.3.6",
    "postcss-loader": "^2.0.5",
    "react-hot-loader": "3.0.0-beta.6",
    "react-test-renderer": "15.6.1",
    "rimraf": "2.6.1",
    "style-loader": "^0.23.1",
    "uglifyjs-webpack-plugin": "^2.1.2",
    "url-loader": "^1.1.2",
    "validate-commit-msg": "2.12.1",
    "webpack": "^4.30.0",
    "webpack-cli": "^3.3.2",
    "webpack-dev-server": "^3.3.1",
    "webpack-parallel-uglify-plugin": "^1.1.0",
    "yargs": "^8.0.1",
    "lean-ui": "git+ssh://git@gitlab.tools.lwork.com:ui/lean-ui.git#master"
  },
  "scripts": {
    "commitmsg": "validate-commit-msg",
    "dev": "NODE_ENV=development webpack-dev-server --config ./webpack_config/dev.js",
    "start": "NODE_ENV=test webpack-dev-server --env.bridge=false --config ./webpack_config/dev.js",
    "test": "NODE_ENV=test jest --env=jsdom",
    "test:watch": "NODE_ENV=test jest --watch --env=jsdom",
    "prod": "rimraf ./dist && NODE_ENV=production webpack --config ./webpack_config/prod.js --progress",
    "prod:qa": "yarn run prod -- --env.folder qa",
    "prod:prod": "yarn run prod -- --env.folder prod",
    "deploy": "node ./deploy.js --folder test",
    "deploy:qa": "node ./deploy.js --folder qa",
    "deploy:prod": "node ./deploy.js --folder prod --env production",
    "deploy-dll": "node ./deploy.js --folder test --dll",
    "deploy-dll:qa": "node ./deploy.js --folder qa --dll",
    "deploy-dll:prod": "node ./deploy.js --folder prod --dll --env production",
    "dll": "yarn dll:prod && yarn dll:dev",
    "dll:dev": "rimraf ./webpack_config/dll_lib/dev && NODE_ENV=development webpack --config ./webpack_config/dll_dev.js",
    "dll:prod": "rimraf ./webpack_config/dll_lib/prod && NODE_ENV=production webpack -p --config ./webpack_config/dll_prod.js --env.folder prod",
    "lint": "eslint",
    "api": "node ./ApiServer",
    "analysis": "yarn run prod -- --profile --json > stats.json"
  },
  "author": "",
  "license": "ISC",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    },
    "validate-commit-msg": {
      "types": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore",
        "revert",
        "build"
      ],
      "scope": {
        "required": false,
        "allowed": [
          "component",
          "action",
          "reducer"
        ],
        "validate": false,
        "multiple": false
      },
      "warnOnFail": false,
      "maxSubjectLength": 100,
      "subjectPattern": ".+",
      "subjectPatternErrorMsg": "subject does not match subject pattern!",
      "helpMessage": "",
      "autoFix": false
    }
  },
  "babel": {
    "presets": [
      "es2015",
      "react",
      "stage-0"
    ]
  },
  "jest": {
    "setupTestFrameworkScriptFile": "./node_modules/jest-enzyme/lib/index.js",
    "mapCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "setupFiles": [
      "<rootDir>/jest-config/setup.js"
    ],
    "moduleFileExtensions": [
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "web.js",
      "js",
      "web.jsx",
      "jsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(js|jsx)$",
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      ".+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest",
      ".+\\.css$": "<rootDir>/jest-config/cssTransform.js",
      "(?!.*\\.(css|json)$)": "<rootDir>/jest-config/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$"
    ]
  }
}
