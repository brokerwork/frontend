  "devDependencies": {
    "add-asset-html-webpack-plugin": "2.0.1",
    "babel-core": "6.24.1",
    "babel-eslint": "^8.0.0",
    "babel-jest": "20.0.3",
    "babel-loader": "7.0.0",
    "babel-preset-es2015": "6.18.0",
    "babel-preset-react": "6.16.0",
    "babel-preset-stage-0": "6.16.0",
    "css-loader": "0.28.1",
    "cssnano": "3.10.0",
    "cz-conventional-changelog": "2.0.0",
    "enzyme": "2.9.1",
    "eslint": "^4.7.0",
    "eslint-config-prettier": "^2.5.0",
    "eslint-plugin-prettier": "^2.3.0",
    "extract-text-webpack-plugin": "^3.0.2",
    "file-loader": "0.9.0",
    "friendly-errors-webpack-plugin": "1.6.1",
    "happypack": "https://github.com/amireh/happypack.git#665c12e5712b972e8667ca545b4e2ea5e0de6535",
    "html-webpack-plugin": "2.28.0",
    "husky": "0.13.3",
    "ip": "1.1.4",
    "jest": "20.0.4",
    "jest-enzyme": "3.8.0",
    "less": "2.7.1",
    "less-loader": "4.0.3",
    "nock": "9.0.14",
    "node-notifier": "5.1.2",
    "os": "0.1.1",
    "oss-easy": "0.3.6",
    "postcss-loader": "1.3.3",
    "prettier": "^1.7.0",
    "react-hot-loader": "next",
    "react-test-renderer": "15.6.1",
    "rimraf": "2.5.4",
    "style-loader": "0.17.0",
    "url-loader": "0.5.8",
    "validate-commit-msg": "2.12.1",
    "webpack": "3.11.0",
    "webpack-dev-server": "2.4.5",
    "webpack-parallel-uglify-plugin": "1.0.0",
    "yargs": "8.0.1"
  },
  "scripts": {
    "commitmsg": "validate-commit-msg",
    "test": "NODE_ENV=test jest --env=jsdom",
    "test:watch": "NODE_ENV=test jest --watch --env=jsdom",
    "start": "cross-env NODE_ENV=development webpack-dev-server --config ./webpack_config/dev.js",
    "start:encrypt": "cross-env NODE_ENV=development webpack-dev-server --env.encrypt=true --config ./webpack_config/dev.js",
    "prod": "rimraf ./dist && NODE_ENV=production webpack --config ./webpack_config/prod.js --progress",
    "prod:qa": "yarn run prod -- --env.folder qa --env.encrypt=true",
    "prod:grey": "yarn run prod -- --env.folder grey",
    "prod:prod": "yarn run prod -- --env.folder prod",
    "deploy": "node ./deploy.js --folder test",
    "deploy:qa": "node ./deploy.js --folder qa",
    "deploy:grey": "node ./deploy.js --folder grey",
    "deploy:prod": "node ./deploy.js --folder prod --env production",
    "deploy-dll": "node ./deploy.js --folder test --dll",
    "deploy-dll:qa": "node ./deploy.js --folder qa --dll",
    "deploy-dll:grey": "node ./deploy.js --folder grey --dll",
    "deploy-dll:prod": "node ./deploy.js --folder prod --dll --env production",
    "dll": "yarn dll:prod && yarn dll:dev",
    "dll:dev": "rimraf ./webpack_config/dll_lib/dev && NODE_ENV=development webpack --config ./webpack_config/dll_dev.js",
    "dll:prod": "rimraf ./webpack_config/dll_lib/prod && NODE_ENV=production webpack -p --config ./webpack_config/dll_prod.js --env.folder prod",
    "lint": "eslint ./src",
    "api": "node ./ApiServer",
    "analysis": "yarn run prod -- --profile --json > stats.json"
  },
  "author": "",
  "license": "ISC",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    },
    "validate-commit-msg": {
      "types": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore",
        "revert",
        "build"
      ],
      "scope": {
        "required": false,
        "allowed": [
          "component",
          "action",
          "reducer"
        ],
        "validate": false,
        "multiple": false
      },
      "warnOnFail": false,
      "maxSubjectLength": 100,
      "subjectPattern": ".+",
      "subjectPatternErrorMsg": "subject does not match subject pattern!",
      "helpMessage": "",
      "autoFix": false
    }
  },
  "babel": {
    "presets": [
      "es2015",
      "react",
      "stage-0"
    ]
  },
  "jest": {
    "setupTestFrameworkScriptFile": "./node_modules/jest-enzyme/lib/index.js",
    "mapCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "setupFiles": [
      "<rootDir>/jest-config/setup.js"
    ],
    "moduleFileExtensions": [
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "web.js",
      "js",
      "web.jsx",
      "jsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(js|jsx)$",
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      ".+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest",
      ".+\\.css$": "<rootDir>/jest-config/cssTransform.js",
      "(?!.*\\.(css|json)$)": "<rootDir>/jest-config/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$"
    ]
  }
}
