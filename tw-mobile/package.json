{
  "name": "tw-mobile",
  "version": "1.0.0",
  "scripts": {
    "ios": "cordova run ios",
    "android": "cordova run android",
    "prepare1": "node config && webpack && cordova prepare",
    "build": "webpack --config ./webpack.pro.config.js",
    "start": "webpack-dev-server --config ./webpack.dev.config.js --progress",
    "test-build": "NODE_ENV=development webpack --config ./webpack.pro.config.js",
    "qa-build": "NODE_ENV=test webpack --config ./webpack.pro.config.js",
    "prod-build": "NODE_ENV=production webpack --config ./webpack.pro.config.js",
    "test-deploy": "node tools/upload/index.js --env test --bucket traderaccount",
    "qa-deploy": "node tools/upload/index.js --env qa --bucket traderaccount",
    "prod-deploy": "node tools/upload/index.js --env prod --bucket traderaccount",
    "test": "echo \"No tests (yet!) -- submit a PR?\" && exit 0"
  },
