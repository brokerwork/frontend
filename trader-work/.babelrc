{
  "presets": [
    ["env", { "modules": false }],
    "es2015",
    "react",
    "stage-0"
  ],
  "plugins": ["react-hot-loader/babel", "transform-runtime", ["import", { "libraryName": "antd", "style": true }]],
  "env": {
    "test": {
      "presets": ["env", "es2015","react", "stage-0"]
    }
  }
}
