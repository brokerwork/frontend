{
  "name": "lworkui",
  "version": "1.0.60",
  "main": "dist/index.js",
  "typings": "lib/index.d.ts",
  "license": "MIT",
  "files": [
    "lib",
    "LeanWork-Icons",
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "iconPath": "node createIconPathData.js",
    "npmPublish": "gulp && npm publish",
    "commitmsg": "validate-commit-msg",
    "export": "build-storybook -c .storybook -o static-web && node deploy.js",
    "start": "start-storybook -p 9001 -c .storybook",
    "build": "webpack --color --progress"
  },
  "dependencies": {
    "classnames": "^2.2.6",
    "omit.js": "1.0.0",
    "oss-easy": "^0.3.6",
    "rc-animate": "2.4.1",
    "rc-calendar": "9.6.0",
    "rc-checkbox": "2.1.5",
    "rc-dialog": "7.4.0",
    "rc-dropdown": "2.1.1",
    "rc-input-number": "4.0.7",
    "rc-menu": "7.4.23",
    "rc-notification": "3.0.1",
    "rc-pagination": "1.15.1",
    "rc-steps": "3.1.0",
    "rc-tabs": "9.2.4",
    "rc-time-picker": "3.3.1",
    "rc-tooltip": "3.7.0",
    "rc-tree": "1.7.11",
    "rc-upload": "2.4.4",
    "rc-util": "4.4.0",
    "react-lazy-load": "3.0.13",
    "warning": "3.0.0"
  },
  "peerDependencies": {
    "classnames": "2.2.5",
    "moment": "2.21.0",
    "prop-types": "15.6.1",
    "react": "15.6.1",
    "react-dom": "15.6.1"
  },
  "devDependencies": {
    "@storybook/addon-actions": "3.3.15",
    "@storybook/addon-knobs": "3.3.15",
    "@storybook/addon-notes": "3.3.14",
    "@storybook/addon-storyshots": "3.3.14",
    "@storybook/addons": "3.3.14",
    "@storybook/react": "3.3.14",
    "@types/classnames": "2.2.3",
    "@types/jest": "22.2.0",
    "@types/prop-types": "15.5.2",
    "@types/react-dom": "16.0.4",
    "antd": "^3.8.1",
    "babel-core": "6.26.0",
    "babel-runtime": "6.26.0",
    "commitizen": "2.9.6",
    "css-loader": "0.28.10",
    "cz-conventional-changelog": "2.1.0",
    "enzyme": "3.3.0",
    "enzyme-adapter-react-16": "1.1.1",
    "extract-text-webpack-plugin": "3.0.2",
    "gulp": "3.9.1",
    "gulp-less": "3.5.0",
    "gulp-typescript": "4.0.2",
    "jest": "22.4.2",
    "less": "2.7.1",
    "less-loader": "4.0.6",
    "merge2": "1.2.2",
    "react": "16.3.0",
    "react-dom": "16.3.0",
    "react-sortable-hoc": "0.6.8",
    "react-storybook-addon-chapters": "2.1.3",
    "react-test-renderer": "16.2.0",
    "shallowequal": "1.0.1",
    "storybook-addon-specifications": "2.1.1",
    "style-loader": "0.20.2",
    "ts-jest": "22.4.1",
    "ts-loader": "3.5.0",
    "typescript": "2.8.3",
    "uglifyjs-webpack-plugin": "^1.2.5",
    "validate-commit-msg": "2.14.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    },
    "validate-commit-msg": {
      "types": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore",
        "revert",
        "build"
      ],
      "scope": {
        "required": false,
        "allowed": [
          "*"
        ],
        "validate": false,
        "multiple": false
      },
      "warnOnFail": false,
      "maxSubjectLength": 100,
      "subjectPattern": ".+",
      "subjectPatternErrorMsg": "subject does not match subject pattern!",
      "helpMessage": "",
      "autoFix": false
    }
  },
  "jest": {
    "setupTestFrameworkScriptFile": "./node_modules/jest-enzyme/lib/index.js",
    "mapCoverage": true,
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "setupFiles": [
      "<rootDir>/jest-config/setup.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(js|jsx)$",
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      ".(ts|tsx)": "<rootDir>/node_modules/ts-jest/preprocessor.js",
      ".+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest",
      ".+\\.css$": "<rootDir>/jest-config/cssTransform.js",
      "(?!.*\\.(css|json)$)": "<rootDir>/jest-config/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$"
    ]
  }
}
